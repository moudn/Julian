# Database
DATABASE_URL=sqlite:///./sales_agent.db

# Signs password-reset tokens — set a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Encrypts Google OAuth tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Empty = derived from SECRET_KEY (development only)
ENCRYPTION_KEY=

# Default scoring threshold for new organizations (per-org after signup)
SCORE_THRESHOLD=50

# Apollo.io
APOLLO_API_KEY=

# OpenRouter (LLM message generation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Lead research (company website + news before writing). RESEARCH_ENABLED
# is a global kill-switch; each org also has its own toggle. SEARCH_API_KEY
# is a Tavily key (free tier) for the news step; empty = website only.
RESEARCH_ENABLED=true
SEARCH_API_KEY=
SEARCH_BASE_URL=https://api.tavily.com

# Google Calendar OAuth app (console.cloud.google.com -> Credentials)
# Each customer connects their own calendar via /integrations/google/connect
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# Stripe (use sk_test_... keys while testing; empty = billing disabled,
# all endpoints open). Get whsec_... from `stripe listen` or the dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Error tracking (optional). Set a Sentry DSN to enable; needs
# sentry-sdk installed (it is in requirements.lock).
SENTRY_DSN=
ENVIRONMENT=development

# SMTP (leave host empty to log emails to console instead of sending)
# Password resets and verification emails go through SMTP too — configure
# it before real signups so those emails actually deliver.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agent@example.com
