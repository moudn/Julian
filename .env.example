# Database
DATABASE_URL=sqlite:///./sales_agent.db

# Signs OAuth state tokens — set a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Default scoring threshold for new organizations (per-org after signup)
SCORE_THRESHOLD=50

# Apollo.io
APOLLO_API_KEY=

# OpenRouter (LLM message generation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Google Calendar OAuth app (console.cloud.google.com -> Credentials)
# Each customer connects their own calendar via /integrations/google/connect
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# Stripe (use sk_test_... keys while testing; empty = billing disabled,
# all endpoints open). Get whsec_... from `stripe listen` or the dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# SMTP (leave host empty to log emails to console instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agent@example.com
