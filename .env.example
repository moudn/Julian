# Database
DATABASE_URL=sqlite:///./sales_agent.db

# Scoring
SCORE_THRESHOLD=50

# Apollo.io
APOLLO_API_KEY=

# OpenRouter (LLM message generation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Google Calendar (OAuth2 access token or service-account token)
GOOGLE_CALENDAR_ID=primary
GOOGLE_ACCESS_TOKEN=

# Sales rep to notify for booking approvals
SALES_REP_EMAIL=rep@example.com

# SMTP (leave host empty to log emails to console instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agent@example.com
